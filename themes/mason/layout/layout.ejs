<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<%- partial('_partial/head') %>
</head>
<body>
<div id="boot" aria-hidden="true" class="notranslate" translate="no"><pre id="boot-text"></pre></div>
<script>(function(){
  var boot=document.getElementById('boot');if(!boot)return;
  var el=document.getElementById('boot-text');
  function remove(){if(boot.parentNode)boot.parentNode.removeChild(boot);}
  function done(){boot.classList.add('done');setTimeout(remove,650);}
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var seen=false;try{seen=sessionStorage.getItem('booted')==='1';}catch(e){}
  if(seen||reduce){boot.style.display='none';remove();return;}
  var lines=[
    {t:'[<span class="ok">  OK  </span>] Booting <span class="label">mason@blog</span>',d:120},
    {t:'[<span class="ok">  OK  </span>] Loading user: <span class="label">曾緯淳 (Mason Zeng)</span>',d:140},
    {t:'[<span class="ok">  OK  </span>] Patents indexed: <span class="label">3</span>',d:120},
    {t:'[<span class="ok">  OK  </span>] Posts indexed: <span class="label"><%= site.posts.length %></span>',d:120},
    {t:'[<span class="warn"> WARN </span>] LLM jailbreak detector: <span class="label">enabled</span>',d:140},
    {t:'[<span class="ok">  OK  </span>] Reached target <span class="label"><%= config.title %></span>',d:160},
    {t:'',d:120},
    {t:'<span class="dim">Last login: 2026-07-14 from 0.0.0.0</span>',d:180}
  ];
  var i=0;
  function next(){
    if(i>=lines.length){try{sessionStorage.setItem('booted','1');}catch(e){}setTimeout(done,350);return;}
    el.innerHTML=el.innerHTML.replace(/<span class="cursor"><\/span>$/,'');
    el.innerHTML+=lines[i++].t+'\n<span class="cursor"></span>';
    setTimeout(next,lines[i-1].d);
  }
  function start(){setTimeout(next,180);}
  if(document.readyState==='complete')start();else window.addEventListener('load',start);
  setTimeout(function(){try{sessionStorage.setItem('booted','1');}catch(e){}done();},4500);
})();</script>
<div class="progress"></div>
<header class="site-header">
  <div class="nav">
    <a class="brand notranslate" translate="no" href="<%- url_for('/') %>"><span class="dot"></span><%= config.title %></a>
    <input type="checkbox" id="navtoggle" class="navtoggle" hidden>
    <label for="navtoggle" class="hamburger" aria-label="menu"><span></span><span></span><span></span></label>
    <nav class="nav-links">
      <a href="<%- url_for('/') %>">首頁</a>
      <a href="<%- url_for('/posts/') %>">文章</a>
      <a href="<%- url_for('/projects/') %>">專案</a>
      <a href="<%- url_for('/about/') %>">關於</a>
      <a href="<%- url_for('/search/') %>">搜尋</a>
      <div class="lang-switch notranslate" translate="no" role="group" aria-label="language">
        <button type="button" data-lang="zh" class="active">中</button>
        <button type="button" data-lang="en">EN</button>
        <button type="button" data-lang="ja">日</button>
      </div>
    </nav>
  </div>
</header>
<main class="wrap"><%- body %></main>
<footer class="site-footer">
  <div class="foot-inner">
    <span class="foot-brand"><%= config.title %></span>
    <span class="foot-count">
      <span id="busuanzi_container_site_pv">總瀏覽 <span id="busuanzi_value_site_pv">–</span></span>
      · <span id="busuanzi_container_site_uv">訪客 <span id="busuanzi_value_site_uv">–</span></span>
    </span>
    <span class="foot-motto">Break things, understand them, rebuild them better.</span>
  </div>
</footer>
<button class="totop" aria-label="top">↑</button>
<script defer src="https://cn.vercount.one/js"></script>
<script>window.SITE_ROOT="<%- url_for('/') %>";</script>
<script src="<%- url_for('/js/blog.js') %>?v=<%= config.asset_v %>"></script>
<script src="<%- url_for('/js/interactive.js') %>?v=<%= config.asset_v %>"></script>
<script src="<%- url_for('/js/translate.js') %>?v=<%= config.asset_v %>"></script>
</body>
</html>
