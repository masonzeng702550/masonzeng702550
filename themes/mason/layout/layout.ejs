<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<%- partial('_partial/head') %>
</head>
<body>
<div class="progress"></div>
<header class="site-header">
  <div class="nav">
    <a class="brand" href="<%- url_for('/') %>"><span class="dot"></span><%= config.title %></a>
    <input type="checkbox" id="navtoggle" class="navtoggle" hidden>
    <label for="navtoggle" class="hamburger" aria-label="menu"><span></span><span></span><span></span></label>
    <nav class="nav-links">
      <a href="<%- url_for('/') %>">首頁</a>
      <a href="<%- url_for('/posts/') %>">文章</a>
      <a href="<%- url_for('/projects/') %>">專案</a>
      <a href="<%- url_for('/about/') %>">關於</a>
      <a href="<%- url_for('/search/') %>">搜尋</a>
    </nav>
  </div>
</header>
<main class="wrap"><%- body %></main>
<footer class="site-footer">
  <div class="foot-inner">
    <span class="foot-brand"><%= config.title %></span>
    <span class="foot-count">
      <span id="busuanzi_container_site_pv">總瀏覽 <span id="busuanzi_value_site_pv">–</span></span>
      · <span id="busuanzi_container_site_uv">訪客 <span id="busuanzi_value_site_uv">–</span></span>
    </span>
    <span class="foot-motto">Break things, understand them, rebuild them better.</span>
  </div>
</footer>
<button class="totop" aria-label="top">↑</button>
<script defer src="https://cn.vercount.one/js"></script>
<script src="<%- url_for('/js/blog.js') %>"></script>
</body>
</html>
