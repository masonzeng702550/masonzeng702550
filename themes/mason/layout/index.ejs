<section class="home-hero reveal">
  <div class="hero-top">
    <div class="hh-tag notranslate" translate="no">~/ whoami</div>
  </div>
  <h1 class="hh-title notranslate" translate="no"><%= config.title %></h1>
  <p class="hh-sub" data-i18n="sub"><%= config.subtitle %></p>
  <p class="hh-bio" data-i18n="bio"><%= config.bio %></p>
  <div class="hh-cta">
    <a class="btn primary" data-i18n="cta_read" href="<%- url_for('/posts/') %>">讀文章</a>
    <a class="btn" data-i18n="cta_proj" href="<%- url_for('/projects/') %>">看專案</a>
    <a class="btn" data-i18n="cta_about" href="<%- url_for('/about/') %>">關於我</a>
  </div>
  <a class="scroll-arrow notranslate" translate="no" href="#featured" aria-label="往下">
    <svg viewBox="0 0 28 12" width="34" height="15" aria-hidden="true"><path d="M3 3 L14 10 L25 3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
</section>

<section id="featured" class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ FEATURED</span><h2 data-i18n="feat">精選文章</h2><a class="hb-more" data-i18n="more" href="<%- url_for('/posts/') %>">全部</a></div>
  <div class="acard-grid">
  <% site.posts.sort('date', -1).limit(6).each(function (post) { %>
    <%- partial('_partial/acard', { post: post }) %>
  <% }) %>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ TOPICS</span><h2 data-i18n="topics">分類與標籤</h2></div>
  <%
    var items = [];
    site.categories.each(function (c) { items.push({ name: c.name, url: url_for(c.path), n: c.length, cat: true }); });
    site.tags.each(function (t) { items.push({ name: t.name, url: url_for(t.path), n: t.length, cat: false }); });
    var maxn = 1; items.forEach(function (i) { if (i.n > maxn) maxn = i.n; });
    items.sort(function (a, b) { return b.n - a.n; });
  %>
  <div class="tagcloud2">
    <div class="tagcloud2-title">目前共有 <b><%= items.length %></b> 個分類與標籤</div>
    <div class="tagcloud2-tags">
    <% items.forEach(function (it, i) {
         var r = it.n / maxn;
         var fs = (0.82 + r * 1.05).toFixed(2);
         var op = (0.6 + r * 0.4).toFixed(2);
         var mt = ((i * 47) % 26) - 13;
         var dl = (((i * 31) % 40) / 10).toFixed(1);
         var du = (3.8 + ((i * 17) % 20) / 10).toFixed(1);
    %>
      <a class="tp <%= it.cat ? 'tp-cat' : 'tp-tag' %>" href="<%= it.url %>"
         style="font-size:<%= fs %>rem;opacity:<%= op %>;margin-top:<%= mt %>px;animation-delay:<%= dl %>s;animation-duration:<%= du %>s"
         title="<%= it.n %> 篇"><%= it.cat ? it.name : ('#' + it.name) %></a>
    <% }) %>
    </div>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ GITHUB</span><h2 data-i18n="gh_h">開發足跡</h2><a class="hb-more" href="https://github.com/masonzeng702550" target="_blank" rel="noopener">@masonzeng702550</a></div>
  <div class="gh-graph">
    <img loading="lazy" alt="GitHub 貢獻折線圖" src="https://github-readme-activity-graph.vercel.app/graph?username=masonzeng702550&bg_color=141517&color=b0b3b8&line=8aa8b6&point=8aa8b6&area=true&area_color=8aa8b6&hide_border=true&custom_title=Contribution+Activity&height=300">
  </div>
  <div class="gh-cal">
    <img loading="lazy" alt="GitHub 貢獻格子圖" src="https://ghchart.rshah.org/8aa8b6/masonzeng702550">
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ PROJECTS</span><h2 data-i18n="projects_h">專案</h2><a class="hb-more" data-i18n="more" href="<%- url_for('/projects/') %>">全部</a></div>
  <%
    var featNames = ['verus-bridge-forensics','secure-vault-solidity','AIS3-ESP32-ICS-Simulator-Hardware-Control','VOXATC-voice_air_traffic_communication_trainer','flightdeck','incense','Elevator-Car-Simulation-Module_for_IEYI2025','keep-awake'];
    var byName = {}; (site.data.projects || []).forEach(function (p) { byName[p.name] = p; });
  %>
  <div class="proj-grid">
  <% featNames.forEach(function (nm) { var p = byName[nm]; if (!p) return; %>
    <a class="proj-card reveal" href="<%= p.url %>" target="_blank" rel="noopener">
      <div class="pc-top"><span class="pc-name"><%= p.name %></span></div>
      <div class="pc-desc"><%= p.desc %></div>
      <% if (p.lang) { %><div class="pc-foot"><span class="pc-lang"><%= p.lang %></span></div><% } %>
    </a>
  <% }) %>
  </div>
</section>

