  <%
    var featNames = ['verus-bridge-forensics','VOXATC-voice_air_traffic_communication_trainer','incense','recycle-ai-tw','my.msfs-flightlog24.com','secure-vault-solidity'];
    var byName = {}; (site.data.projects || []).forEach(function (p) { byName[p.name] = p; });
  %>
  <div class="proj-grid">
  <% featNames.forEach(function (nm) { var p = byName[nm]; if (!p) return; %>
    <a class="proj-card reveal" href="<%= p.url %>" target="_blank" rel="noopener">
      <div class="pc-top"><span class="pc-name"><%= p.name %></span><% if (p.stars > 0) { %><span class="pc-star">★ <%= p.stars %></span><% } %></div>
      <div class="pc-desc"><%= p.desc %></div>
      <% if (p.lang) { %><div class="pc-foot"><span class="pc-lang"><%= p.lang %></span></div><% } %>
    </a>
  <% }) %>
  </div>
</section>

