<section class="home-hero reveal">
  <div class="hero-top">
    <div class="hh-tag">~/ whoami</div>
    <div class="lang-switch" role="group" aria-label="language">
      <button data-lang="zh" class="active">中</button>
      <button data-lang="en">EN</button>
      <button data-lang="ja">日</button>
    </div>
  </div>
  <h1 class="hh-title"><%= config.title %></h1>
  <p class="hh-sub" data-i18n="sub"><%= config.subtitle %></p>
  <p class="hh-bio" data-i18n="bio"><%= config.bio %></p>
  <div class="hh-cta">
    <a class="btn primary" data-i18n="cta_read" href="<%- url_for('/posts/') %>">讀文章</a>
    <a class="btn" data-i18n="cta_proj" href="<%- url_for('/projects/') %>">看專案</a>
    <a class="btn" data-i18n="cta_about" href="<%- url_for('/about/') %>">關於我</a>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ FEATURED</span><h2 data-i18n="feat">精選文章</h2><a class="hb-more" data-i18n="more" href="<%- url_for('/posts/') %>">全部</a></div>
  <div class="post-list">
  <% site.posts.sort('date', -1).limit(4).each(function (post) { %>
    <a class="pcard reveal" href="<%- url_for(post.path) %>">
      <div class="pdate"><%= date(post.date, 'YYYY-MM-DD') %></div>
      <div class="ptitle"><%= post.title %></div>
      <% if (post.excerpt) { %><div class="pexcerpt"><%= post.excerpt %></div><% } %>
      <div class="pmeta">
        <% post.categories.each(function (c) { %><span><%= c.name %></span><% }) %>
        <% post.tags.each(function (t) { %><span>#<%= t.name %></span><% }) %>
      </div>
    </a>
  <% }) %>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ TOPICS</span><h2 data-i18n="topics">分類與標籤</h2></div>
  <%
    var items = [];
    site.categories.each(function (c) { items.push({ name: c.name, url: url_for(c.path), n: c.length, cat: true }); });
    site.tags.each(function (t) { items.push({ name: t.name, url: url_for(t.path), n: t.length, cat: false }); });
    var maxn = 1; items.forEach(function (i) { if (i.n > maxn) maxn = i.n; });
    items.sort(function (a, b) { return b.n - a.n; });
  %>
  <div class="tagcloud2">
    <div class="tagcloud2-title">目前共有 <b><%= items.length %></b> 個分類與標籤</div>
    <div class="tagcloud2-tags">
    <% items.forEach(function (it, i) {
         var r = it.n / maxn;
         var fs = (0.82 + r * 1.15).toFixed(2);
         var op = (0.62 + r * 0.38).toFixed(2);
         var mt = ((i * 47) % 30) - 15;      // -15..14 px 垂直錯落
         var dl = (((i * 31) % 40) / 10).toFixed(1);  // 0..3.9s 浮動延遲
         var du = (3.4 + ((i * 17) % 20) / 10).toFixed(1); // 3.4..5.3s 週期
    %>
      <a class="tp <%= it.cat ? 'tp-cat' : 'tp-tag' %>" href="<%= it.url %>"
         style="font-size:<%= fs %>rem;opacity:<%= op %>;margin-top:<%= mt %>px;animation-delay:<%= dl %>s;animation-duration:<%= du %>s"
         title="<%= it.n %> 篇"><%= it.cat ? it.name : ('#' + it.name) %></a>
    <% }) %>
    </div>
  </div>
</section>

<script>
(function () {
  var I18N = {
    zh: {
      sub: '資安 · 航空 · 升學心得',
      bio: '資安研究 · CTF 出題 · 學生飛行員 · 生成式 AI。臺北市數位實驗高中，把學到的東西寫成文章。',
      cta_read: '讀文章', cta_proj: '看專案', cta_about: '關於我',
      feat: '精選文章', more: '全部', topics: '分類與標籤', bubblenote: ''
    },
    en: {
      sub: 'Security · Aviation · Study Notes',
      bio: 'Security research, CTF authoring, student pilot, generative AI. A student at Taipei Municipal Digital Experimental High School — writing about what I learn.',
      cta_read: 'Read Posts', cta_proj: 'Projects', cta_about: 'About',
      feat: 'Featured', more: 'All', topics: 'Topics & Tags', bubblenote: ''
    },
    ja: {
      sub: 'セキュリティ・航空・受験記録',
      bio: 'セキュリティ研究・CTF作問・学生パイロット・生成AI。台北市デジタル実験高校の学生で、学んだことを記事にしています。',
      cta_read: '記事を読む', cta_proj: 'プロジェクト', cta_about: '私について',
      feat: '注目の記事', more: 'すべて', topics: 'カテゴリとタグ', bubblenote: ''
    }
  };
  var btns = document.querySelectorAll('.lang-switch button');
  function apply(lang) {
    var dict = I18N[lang] || I18N.zh;
    document.querySelectorAll('[data-i18n]').forEach(function (el) {
      var k = el.getAttribute('data-i18n');
      if (dict[k]) el.textContent = dict[k];
    });
    btns.forEach(function (b) { b.classList.toggle('active', b.getAttribute('data-lang') === lang); });
    try { localStorage.setItem('home-lang', lang); } catch (e) {}
    document.documentElement.setAttribute('data-home-lang', lang);
  }
  btns.forEach(function (b) { b.addEventListener('click', function () { apply(b.getAttribute('data-lang')); }); });
  var saved = 'zh';
  try { saved = localStorage.getItem('home-lang') || 'zh'; } catch (e) {}
  if (saved !== 'zh') apply(saved);
})();
</script>
