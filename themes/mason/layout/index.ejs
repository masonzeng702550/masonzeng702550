      <button data-lang="zh" class="active">中</button>
      <button data-lang="en">EN</button>
      <button data-lang="ja">日</button>
    </div>
  </div>
  <h1 class="hh-title notranslate" translate="no"><%= config.title %></h1>
  <p class="hh-sub" data-i18n="sub"><%= config.subtitle %></p>
  <p class="hh-bio" data-i18n="bio"><%= config.bio %></p>
  <div class="hh-cta">
    <a class="btn primary" data-i18n="cta_read" href="<%- url_for('/posts/') %>">讀文章</a>
    <a class="btn" data-i18n="cta_proj" href="<%- url_for('/projects/') %>">看專案</a>
    <a class="btn" data-i18n="cta_about" href="<%- url_for('/about/') %>">關於我</a>
  </div>
  <a class="scroll-cue notranslate" translate="no" href="#whoami" aria-label="scroll down">SCROLL <span class="cue-ar">▼</span></a>
