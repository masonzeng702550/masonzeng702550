<section class="home-hero reveal">
  <div class="hero-top">
    <div class="hh-tag notranslate" translate="no">~/ whoami</div>
    <div class="lang-switch notranslate" translate="no" role="group" aria-label="language">
      <button data-lang="zh" class="active">中</button>
      <button data-lang="en">EN</button>
      <button data-lang="ja">日</button>
    </div>
  </div>
  <h1 class="hh-title notranslate" translate="no"><%= config.title %></h1>
  <p class="hh-sub" data-i18n="sub"><%= config.subtitle %></p>
  <p class="hh-bio" data-i18n="bio"><%= config.bio %></p>
  <div class="hh-cta">
    <a class="btn primary" data-i18n="cta_read" href="<%- url_for('/posts/') %>">讀文章</a>
    <a class="btn" data-i18n="cta_proj" href="<%- url_for('/projects/') %>">看專案</a>
    <a class="btn" data-i18n="cta_about" href="<%- url_for('/about/') %>">關於我</a>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ FEATURED</span><h2 data-i18n="feat">精選文章</h2><a class="hb-more" data-i18n="more" href="<%- url_for('/posts/') %>">全部</a></div>
  <div class="acard-grid">
  <% site.posts.sort('date', -1).limit(6).each(function (post) { %>
    <%- partial('_partial/acard', { post: post }) %>
  <% }) %>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ TOPICS</span><h2 data-i18n="topics">分類與標籤</h2></div>
  <%
    var items = [];
    site.categories.each(function (c) { items.push({ name: c.name, url: url_for(c.path), n: c.length, cat: true }); });
    site.tags.each(function (t) { items.push({ name: t.name, url: url_for(t.path), n: t.length, cat: false }); });
    var maxn = 1; items.forEach(function (i) { if (i.n > maxn) maxn = i.n; });
    items.sort(function (a, b) { return b.n - a.n; });
  %>
  <div class="tagcloud2">
    <div class="tagcloud2-title">目前共有 <b><%= items.length %></b> 個分類與標籤</div>
    <div class="tagcloud2-tags">
    <% items.forEach(function (it, i) {
         var r = it.n / maxn;
         var fs = (0.82 + r * 1.15).toFixed(2);
         var op = (0.62 + r * 0.38).toFixed(2);
         var mt = ((i * 47) % 30) - 15;      // -15..14 px 垂直錯落
         var dl = (((i * 31) % 40) / 10).toFixed(1);  // 0..3.9s 浮動延遲
         var du = (3.4 + ((i * 17) % 20) / 10).toFixed(1); // 3.4..5.3s 週期
    %>
      <a class="tp <%= it.cat ? 'tp-cat' : 'tp-tag' %>" href="<%= it.url %>"
         style="font-size:<%= fs %>rem;opacity:<%= op %>;margin-top:<%= mt %>px;animation-delay:<%= dl %>s;animation-duration:<%= du %>s"
         title="<%= it.n %> 篇"><%= it.cat ? it.name : ('#' + it.name) %></a>
    <% }) %>
    </div>
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ GITHUB</span><h2>開發足跡</h2><a class="hb-more" href="https://github.com/masonzeng702550" target="_blank" rel="noopener">@masonzeng702550</a></div>
  <div class="gh-graph">
    <img loading="lazy" alt="GitHub 貢獻活動圖" src="https://github-readme-activity-graph.vercel.app/graph?username=masonzeng702550&bg_color=0f1422&color=22d3ee&line=a78bfa&point=ffffff&area=true&area_color=22d3ee&hide_border=true&custom_title=Contribution+Activity&height=300">
  </div>
  <div class="gh-stats">
    <img loading="lazy" alt="GitHub 統計" src="https://github-readme-stats-roan-five.vercel.app/api?username=masonzeng702550&show_icons=true&hide_border=true&theme=transparent&title_color=22d3ee&icon_color=22d3ee&text_color=cbd5e1&include_all_commits=true&count_private=true">
    <img loading="lazy" alt="常用語言" src="https://github-readme-stats-roan-five.vercel.app/api/top-langs/?username=masonzeng702550&layout=compact&hide_border=true&theme=transparent&title_color=22d3ee&text_color=cbd5e1&langs_count=8">
  </div>
</section>

<section class="home-block reveal">
  <div class="hb-head"><span class="hb-k">§ PROJECTS</span><h2>酷專案</h2><a class="hb-more" href="<%- url_for('/projects/') %>">全部</a></div>
  <%
    var featNames = ['verus-bridge-forensics','VOXATC-voice_air_traffic_communication_trainer','incense','recycle-ai-tw','my.msfs-flightlog24.com','secure-vault-solidity'];
    var byName = {}; (site.data.projects || []).forEach(function (p) { byName[p.name] = p; });
  %>
  <div class="proj-grid">
  <% featNames.forEach(function (nm) { var p = byName[nm]; if (!p) return; %>
    <a class="proj-card reveal" href="<%= p.url %>" target="_blank" rel="noopener">
      <div class="pc-top"><span class="pc-name"><%= p.name %></span><% if (p.stars > 0) { %><span class="pc-star">★ <%= p.stars %></span><% } %></div>
      <div class="pc-desc"><%= p.desc %></div>
      <% if (p.lang) { %><div class="pc-foot"><span class="pc-lang"><%= p.lang %></span></div><% } %>
    </a>
  <% }) %>
  </div>
</section>

<!-- whole-page auto translation via Google Website Translator, driven by the 中/EN/日 buttons -->
<div id="google_translate_element" aria-hidden="true"></div>
<script>
(function () {
  var btns = document.querySelectorAll('.lang-switch button');
  function cookie(v) {
    var host = location.hostname;
    document.cookie = 'googtrans=' + v + ';path=/';
    document.cookie = 'googtrans=' + v + ';path=/;domain=' + host;
    document.cookie = 'googtrans=' + v + ';path=/;domain=.' + host;
  }
  function setLang(lang) {           // 'zh' = original, else 'en' / 'ja'
    if (lang === 'zh') cookie('');
    else cookie('/zh-CN/' + lang);
    location.reload();
  }
  btns.forEach(function (b) {
    b.addEventListener('click', function () { setLang(b.getAttribute('data-lang')); });
  });
  // mark active from current cookie
  var m = document.cookie.match(/googtrans=\/[^/]+\/(\w+)/);
  var cur = (m && m[1] && m[1] !== 'zh' && m[1] !== 'zh-TW') ? m[1] : 'zh';
  btns.forEach(function (b) { b.classList.toggle('active', b.getAttribute('data-lang') === cur); });
})();
function googleTranslateElementInit() {
  new google.translate.TranslateElement({ pageLanguage: 'zh-CN', includedLanguages: 'en,ja', autoDisplay: false }, 'google_translate_element');
}
</script>
<script src="https://translate.googleapis.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
