<div class="page-head reveal">
  <span class="ph-k"><%= page.tag ? 'Tag' : (page.category ? 'Category' : 'Archives') %></span>
  <h1><%= page.tag || page.category || '全部文章' %></h1>
</div>
<div class="acard-grid">
<% page.posts.sort('date', -1).each(function (post) { %>
  <%- partial('_partial/acard', { post: post }) %>
<% }) %>
</div>
<% if (page.total > 1) { %>
<div class="pager">
  <% if (page.prev) { %><a href="<%- url_for(page.prev_link) %>">← 新</a><% } else { %><span>← 新</span><% } %>
  <span><%= page.current %> / <%= page.total %></span>
  <% if (page.next) { %><a href="<%- url_for(page.next_link) %>">舊 →</a><% } else { %><span>舊 →</span><% } %>
</div>
<% } %>
