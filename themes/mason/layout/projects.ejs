<div class="page-head reveal">
  <span class="ph-k">§ PROJECTS</span>
  <h1><%= page.title || '開源專案' %></h1>
  <p class="ph-sub">GitHub 上的公開專案，依領域分組。可直接在此加星或 fork。</p>
</div>
<%
  var groups = {};
  (site.data.projects || []).forEach(function (p) { (groups[p.domain] = groups[p.domain] || []).push(p); });
  var order = ['資安', 'CTF', '軟硬體', '航空', '氣候', '日本', '工具', '其他'];
%>
<% order.forEach(function (dom) { if (!groups[dom]) return; %>
  <div class="proj-group reveal">
    <h2 class="proj-dom"><span class="pd-dot"></span><%= dom %><span class="pd-count"><%= groups[dom].length %></span></h2>
    <div class="proj-grid">
    <% groups[dom].forEach(function (p) { %>
      <div class="proj-card">
        <div class="pc-top">
          <a class="pc-name" href="<%= p.url %>" target="_blank" rel="noopener"><%= p.name %></a>
          <% if (p.stars > 0) { %><span class="pc-star">★ <%= p.stars %></span><% } %>
        </div>
        <div class="pc-desc"><%= p.desc || '—' %></div>
        <div class="pc-foot">
          <% if (p.lang) { %><span class="pc-lang"><%= p.lang %></span><% } %>
          <span class="gh-btns">
            <a class="github-button" href="<%= p.url %>" data-color-scheme="no-preference: dark; light: dark; dark: dark;" data-icon="octicon-star" data-size="small" aria-label="Star <%= p.name %> on GitHub">Star</a>
            <a class="github-button" href="<%= p.url %>/fork" data-color-scheme="no-preference: dark; light: dark; dark: dark;" data-icon="octicon-repo-forked" data-size="small" aria-label="Fork <%= p.name %> on GitHub">Fork</a>
          </span>
        </div>
      </div>
    <% }) %>
    </div>
  </div>
<% }) %>
<script async defer src="https://buttons.github.io/buttons.js"></script>
